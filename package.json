{
  "name": "modern-web-starter",
  "version": "0.1.0",
  "private": false,
  "description": "Modern web monorepo template with turborepo, TypeScript, Hono, and React — ready for AI-powered apps",
  "homepage": "https://github.com/fgbyte/modern-web-starter#readme",
  "bugs": {
    "url": "https://github.com/fgbyte/modern-web-starter/issues"
  },
  "license": "MIT",
  "author": "fgbyte",
  "repository": {
    "type": "git",
    "url": "https://github.com/fgbyte/modern-web-starter.git"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "hono": "^4.12.23",
      "typescript": "^6.0.3",
      "@types/node": "^25.9.2",
      "@cloudflare/workers-types": "^4.20260511.1",
      "bun-types": "^1.3.14",
      "better-auth": "^1.6.14",
      "alchemy": "^0.93.11",
      "vitest": "^4.1.8",
      "@vitest/ui": "^4.1.8",
      "@vitest/coverage-v8": "^4.1.8",
      "jsdom": "^29.1.1"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo -F @modern-web-starter/infra dev",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "deploy:dev": "bun run --filter @modern-web-starter/infra deploy:dev",
    "deploy:staging": "bun run --filter @modern-web-starter/infra deploy:staging",
    "deploy:prod": "bun run --filter @modern-web-starter/infra deploy:prod",
    "destroy:dev": "bun run --filter @modern-web-starter/infra destroy:dev",
    "destroy:staging": "bun run --filter @modern-web-starter/infra destroy:staging",
    "destroy:prod": "bun run --filter @modern-web-starter/infra destroy:prod",
    "check-types": "turbo check-types",
    "db:studio": "turbo -F @modern-web-starter/db db:studio",
    "db:generate": "turbo -F @modern-web-starter/db db:generate",
    "db:migrate": "turbo -F @modern-web-starter/db db:migrate",
    "test": "turbo test --filter=web --filter=server",
    "test:server": "bun run --cwd apps/server test",
    "test:web": "bun run --cwd apps/web test",
    "open-auth-docs": "open-cli http://localhost:3000/api/auth/reference",
    "init": "bun run scripts/init.ts",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@modern-web-starter/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@modern-web-starter/config": "workspace:*",
    "@types/node": "catalog:",
    "bun-types": "catalog:",
    "open-cli": "^9.0.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}